# Copy this to .env for local development (never commit .env)

# Your Requesty API key (from https://app.requesty.ai)
REQUESTY_API_KEY=your_key_here

# Login password for the web interface
CHAT_PASSWORD=LeoChandra2013!

# Random secret for signing session cookies — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_hex_string

# Path to the SQLite database file
# On Railway: set this to /data/sessions.db and add a Volume mounted at /data
DB_PATH=sessions.db
